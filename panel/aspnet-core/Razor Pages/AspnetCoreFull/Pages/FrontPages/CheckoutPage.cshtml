}

@* ************** Content ************** *@

<section class="section-py bg-body first-section-pt">
  <div class="container">
    <!--/ Checkout Wizard -->
    @await Html.PartialAsync("../_Partials/WizardCheckout")

    <!-- Add new address modal -->
    @await Html.PartialAsync("../_Partials/_Modals/ModalAddNewAddress")
  </div>
</section>
