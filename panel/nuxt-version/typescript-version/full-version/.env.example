# Base URL of the P2 Player backend API (include the /api/v1 prefix).
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Nuxt app base URL (usually "/").
NUXT_APP_BASE_URL=/

# Legacy nuxt-auth vars (unused now that auth is cookie-based JWT; kept for the
# inert @sidebase/nuxt-auth module to boot without warnings).
AUTH_ORIGIN=
AUTH_SECRET=

# Optional maps token (unused by the admin panel).
MAPBOX_ACCESS_TOKEN=
